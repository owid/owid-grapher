{
    "compilerOptions": {
        "isolatedModules": true,
        "composite": true,

        "target": "es2023",
        "module": "es2022",
        "moduleResolution": "bundler",
        "lib": ["esnext"],
        "types": ["@cloudflare/workers-types"],
        "esModuleInterop": true,

        // Emit declarations (into the gitignored ./_dist) so this project can
        // be referenced by other composite projects, e.g. the admin client's
        // dumbbell table preview page imports the search data-table builder.
        // The outDir MUST stay underscore-prefixed: `wrangler pages` scans the
        // whole functions/ tree for file-based routes, and a non-prefixed dist/
        // gets picked up as routes (Pages ignores any path starting with _).
        "outDir": "./_dist",
        "skipLibCheck": true,
        "resolveJsonModule": true,

        "strict": true,
        "alwaysStrict": true,
        "allowJs": false,
        "jsx": "react-jsx",

        "noImplicitOverride": true
    },
    "references": [
        { "path": "../packages/@ourworldindata/components" },
        { "path": "../packages/@ourworldindata/core-table" },
        { "path": "../packages/@ourworldindata/explorer" },
        { "path": "../packages/@ourworldindata/grapher" },
        { "path": "../packages/@ourworldindata/types" },
        { "path": "../packages/@ourworldindata/utils" }
    ]
}
