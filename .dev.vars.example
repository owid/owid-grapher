# env vars for local development of /functions/donation/donate.ts Cloudflare pages function
# rename to .dev.vars and fill in the values from the homonymous "(dev)" keys in 1Password

# Should be set to "production" in prod deployment. Defaults to "production" if unset.
ENV=development

# https://dashboard.stripe.com/test/apikeys
# required by /donation/donate
STRIPE_API_KEY=

# https://dash.cloudflare.com/?to=/:account/turnstile
# required by /donation/donate
# for testing: https://developers.cloudflare.com/turnstile/troubleshooting/testing/
TURNSTILE_SECRET_KEY=

# required by /donation/thank-you
# see README for getting STRIPE_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET=
MAILGUN_DOMAIN=
MAILGUN_SENDING_KEY=

# for subscribing a donor to the donor newsletter
MAILCHIMP_API_KEY=
MAILCHIMP_API_SERVER=
MAILCHIMP_DONOR_LIST_ID=

# for subscribing to the OWID Brief newsletter via
# /api/email-notifications/subscribe. If unset, the Mailchimp call is skipped
# (useful for local development).
MAILCHIMP_NEWSLETTER_LIST_ID=
# Mailchimp interest (group) id of "The OWID Brief" in the newsletter list
MAILCHIMP_OWID_BRIEF_INTEREST_ID=

# for sending the email notifications welcome email via
# /api/email-notifications/subscribe. If unset, sending is skipped
# (useful for local development).
POSTMARK_SERVER_TOKEN=

# analytics
CLOUDFLARE_GOOGLE_ANALYTICS_MEASUREMENT_PROTOCOL_KEY=
CLOUDFLARE_GOOGLE_ANALYTICS_MEASUREMENT_ID=
CLOUDFLARE_GOOGLE_ANALYTICS_SAMPLING_RATE=

# optional
SLACK_BOT_OAUTH_TOKEN=
SLACK_ERROR_CHANNEL_ID=C016H0BNNB1 #bot-testing channel

GRAPHER_CONFIG_R2_BUCKET_PATH=devs/YOURNAME
