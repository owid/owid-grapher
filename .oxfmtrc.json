{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "printWidth": 80,
    "semi": false,
    "tabWidth": 4,
    "trailingComma": "es5",
    "overrides": [
        {
            "files": ["*.jsonc"],
            "options": {
                "trailingComma": "none"
            }
        },
        {
            "files": ["*.yml", "*.yaml"],
            "options": {
                "tabWidth": 2
            }
        }
    ],
    "ignorePatterns": [
        ".tscache",
        "/bakedSite",
        "/localBake",
        "datasetsExport",
        "itsJustJavascript",
        "package.json",
        "coverage",
        "packages/@ourworldindata/*/dist/",
        "dist/",
        "grapherData/",
        ".vscode/",
        ".claude/settings.local.json",
        "*.handlebars"
    ]
}
